# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Service (optional)
VITE_AI_DEFAULT_PROVIDER=openai
# Don't store API keys here - configure in app Settings

# Push Notifications (VAPID)
# Generate keys with: npx web-push generate-vapid-keys
# The private counterpart must be set on the Supabase send-notification function
# as VAPID_PRIVATE_KEY + VAPID_PUBLIC_KEY + VAPID_EMAIL.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
