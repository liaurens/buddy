# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Service (optional)
VITE_AI_DEFAULT_PROVIDER=openai
# Don't store API keys here - configure in app Settings

# Push Notifications (VAPID)
# Generate keys with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Google Calendar OAuth
# Get from: console.cloud.google.com > APIs > Credentials > OAuth 2.0 Client IDs
# Redirect URI to add: https://<your-project>.supabase.co/functions/v1/google-calendar-auth
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Supabase Edge Function secrets (set via: supabase secrets set KEY=value)
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# FRONTEND_URL=https://buddy4life.netlify.app
